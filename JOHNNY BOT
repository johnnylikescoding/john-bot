<!DOCTYPE html>
<html lang="en" data-theme="dark">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>John Bot • Your AI Assistant</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.6.0/css/all.min.css">
  <style>
    body { font-family: 'Segoe UI', system-ui, sans-serif; }
    .chat-container { max-height: calc(100vh - 180px); }
    .message { max-width: 80%; }
  </style>
</head>
<body class="bg-gray-950 text-gray-100 min-h-screen">
  <div class="max-w-4xl mx-auto p-4">
    <!-- Header -->
    <div class="flex items-center justify-between mb-6 pt-4">
      <div class="flex items-center gap-3">
        <div class="w-12 h-12 bg-blue-600 rounded-2xl flex items-center justify-center text-2xl">
          🤖
        </div>
        <div>
          <h1 class="text-3xl font-bold">John Bot</h1>
          <p class="text-green-400 text-sm flex items-center gap-1">
            <span class="w-2 h-2 bg-green-400 rounded-full animate-pulse"></span>
            Online • Powered by Grok
          </p>
        </div>
      </div>
      <button onclick="toggleSettings()" class="p-3 hover:bg-gray-800 rounded-xl">
        <i class="fas fa-cog text-xl"></i>
      </button>
    </div>

    <!-- Chat Area -->
    <div id="chat" class="chat-container bg-gray-900 rounded-3xl p-6 overflow-y-auto mb-6 shadow-2xl border border-gray-800">
      <!-- Messages will appear here -->
    </div>

    <!-- Input Area -->
    <div class="flex gap-3">
      <input 
        id="user-input" 
        type="text" 
        placeholder="Ask me anything..." 
        class="flex-1 bg-gray-900 border border-gray-700 rounded-2xl px-6 py-4 focus:outline-none focus:border-blue-500 text-lg"
        onkeypress="if(event.key === 'Enter') sendMessage()">
      <button 
        onclick="sendMessage()"
        class="bg-blue-600 hover:bg-blue-700 px-8 rounded-2xl font-medium transition">
        Send
      </button>
    </div>

    <p class="text-center text-xs text-gray-500 mt-4">John Bot • Made for you by Grok</p>
  </div>

  <!-- Settings Modal -->
  <div id="settings" class="hidden fixed inset-0 bg-black/80 flex items-center justify-center">
    <div class="bg-gray-900 rounded-3xl p-8 max-w-md w-full mx-4">
      <h2 class="text-2xl font-bold mb-6">John Bot Settings</h2>
      
      <label class="block mb-2 text-sm">xAI Grok API Key</label>
      <input id="api-key" type="password" placeholder="xai-..." 
             class="w-full bg-gray-800 border border-gray-700 rounded-xl px-4 py-3 mb-6">
      
      <label class="block mb-2 text-sm">Model</label>
      <select id="model" class="w-full bg-gray-800 border border-gray-700 rounded-xl px-4 py-3 mb-6">
        <option value="grok-4.3">Grok 4.3 (Best)</option>
        <option value="grok-3">Grok 3</option>
      </select>

      <button onclick="saveSettings()" 
              class="w-full bg-blue-600 py-4 rounded-2xl font-medium hover:bg-blue-700">
        Save & Close
      </button>
      <button onclick="toggleSettings()" 
              class="w-full mt-3 py-4 text-gray-400 hover:text-white">
        Cancel
      </button>
    </div>
  </div>

  <script>
    let messages = [];
    
    function addMessage(text, isUser) {
      const chat = document.getElementById('chat');
      const msg = document.createElement('div');
      msg.className = `flex mb-6 ${isUser ? 'justify-end' : 'justify-start'}`;
      msg.innerHTML = `
        <div class="${isUser ? 'bg-blue-600' : 'bg-gray-800'} message rounded-3xl px-6 py-4">
          ${text}
        </div>
      `;
      chat.appendChild(msg);
      chat.scrollTop = chat.scrollHeight;
    }

    async function sendMessage() {
      const input = document.getElementById('user-input');
      const text = input.value.trim();
      if (!text) return;

      addMessage(text, true);
      input.value = '';

      const apiKey = localStorage.getItem('johnbot_apikey') || '';
      if (!apiKey) {
        addMessage("Please add your xAI API key in settings first!", false);
        return;
      }

      // Show thinking
      const thinkingId = 'thinking-' + Date.now();
      const chat = document.getElementById('chat');
      chat.innerHTML += `<div id="${thinkingId}" class="text-gray-500 italic pl-4">John Bot is thinking...</div>`;
      chat.scrollTop = chat.scrollHeight;

      try {
        const response = await fetch('https://api.x.ai/v1/chat/completions', {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
            'Authorization': `Bearer ${apiKey}`
          },
          body: JSON.stringify({
            model: document.getElementById('model').value || "grok-4.3",
            messages: [
              { role: "system", content: "You are John Bot, a helpful, friendly, and slightly witty AI assistant created for John. Be concise but warm." },
              ...messages,
              { role: "user", content: text }
            ],
            temperature: 0.8,
            max_tokens: 1024
          })
        });

        document.getElementById(thinkingId).remove();

        const data = await response.json();
        const reply = data.choices[0].message.content;
        
        messages.push({role: "user", content: text});
        messages.push({role: "assistant", content: reply});
        
        addMessage(reply, false);
      } catch (e) {
        document.getElementById(thinkingId).remove();
        addMessage("Sorry, something went wrong. Check your API key.", false);
      }
    }

    function toggleSettings() {
      document.getElementById('settings').classList.toggle('hidden');
      document.getElementById('api-key').value = localStorage.getItem('johnbot_apikey') || '';
    }

    function saveSettings() {
      const key = document.getElementById('api-key').value.trim();
      if (key) localStorage.setItem('johnbot_apikey', key);
      toggleSettings();
    }

    // Welcome message
    window.onload = () => {
      addMessage("Hello! I'm John Bot 👋 Your personal AI assistant. How can I help you today?", false);
    };
  </script>
</body>
</html>